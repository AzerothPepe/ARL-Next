FROM debian:bookworm

ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai
ENV NODE_PATH=/usr/local/lib/node_modules

# 替换源为阿里云镜像 (Debian 源不区分 arm64/amd64 的域名，维护更简单)
# 使用默认的 Debian 源（因为在 GitHub Actions 海外节点编译，默认源最快）
RUN apt-get update -o Acquire::Retries=10 && \
    apt-get install -y --no-install-recommends \
    wget unzip bzip2 git curl tzdata \
    gcc g++ make automake autoconf libtool \
    libffi-dev libssl-dev python3 python3-dev python3-pip python3-venv \
    libxml2-dev libxslt1-dev zlib1g-dev \
    ca-certificates libnss3 libatk-bridge2.0-0 libgtk-3-0 libx11-xcb1 \
    libxcb-dri3-0 libxcomposite1 libxdamage1 libxrandr2 libgbm1 \
    libasound2 libxshmfence1 libdrm2 libxkbcommon0 libatspi2.0-0 libcups2 \
    fontconfig nodejs npm fonts-wqy-zenhei fonts-wqy-microhei chromium chromium-common && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g puppeteer-core@10.4.0 && npm cache clean --force

# 编译 MassDNS
RUN cd /tmp && \
    (wget -t 10 https://github.com/blechschmidt/massdns/archive/refs/tags/v1.1.0.tar.gz || wget -t 10 https://gh-proxy.com/https://github.com/blechschmidt/massdns/archive/refs/tags/v1.1.0.tar.gz) && \
    tar xvf v1.1.0.tar.gz && cd massdns-1.1.0 && make -j$(nproc) && \
    cp bin/massdns /usr/local/bin/massdns && chmod +x /usr/local/bin/massdns && \
    cd /tmp && rm -rf massdns*

# 编译 Nmap
RUN cd /tmp && \
    wget https://nmap.org/dist/nmap-7.95.tar.bz2 && \
    bzip2 -cd nmap-7.95.tar.bz2 | tar xvf - && cd nmap-7.95 && \
    ./configure --without-zenmap && make && make install && cd /tmp && rm -rf nmap* && \
    (wget -O /usr/local/share/nmap/nmap-service-probes https://fastly.jsdelivr.net/gh/nmap/nmap@master/nmap-service-probes || wget -O /usr/local/share/nmap/nmap-service-probes https://gh-proxy.com/https://raw.githubusercontent.com/nmap/nmap/master/nmap-service-probes)

# 下载 Nuclei
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "amd64" ]; then NUCLEI_ZIP="nuclei_3.3.0_linux_amd64.zip"; else NUCLEI_ZIP="nuclei_3.3.0_linux_arm64.zip"; fi && \
    wget -t 10 "https://github.com/projectdiscovery/nuclei/releases/download/v3.3.0/$NUCLEI_ZIP" -O $NUCLEI_ZIP || wget -t 10 "https://gh-proxy.com/https://github.com/projectdiscovery/nuclei/releases/download/v3.3.0/$NUCLEI_ZIP" -O $NUCLEI_ZIP && \
    unzip $NUCLEI_ZIP && mv nuclei /usr/local/bin/ && chmod +x /usr/local/bin/nuclei && /usr/local/bin/nuclei -update-templates || true

# 设置工作目录并拷贝后端源码到容器
WORKDIR /code
COPY ./backend /code/backend

# 在构建镜像时就创建好虚拟环境并安装好依赖，使生产环境自包含
# 全局安装必备组件（默认海外源）
RUN python3 -m venv /code/backend/.venv-docker && \
    npm install -g pnpm pm2 && npm cache clean --force && \
    /code/backend/.venv-docker/bin/pip install --no-cache-dir --upgrade pip && \
    /code/backend/.venv-docker/bin/pip install --no-cache-dir -r /code/backend/requirements.txt && \
    /code/backend/.venv-docker/bin/pip install --no-cache-dir -e /code/backend/ARL-NPoC/ && \
    apt-get purge -y gcc g++ make automake autoconf libtool python3-dev libxml2-dev libxslt1-dev zlib1g-dev libffi-dev libssl-dev && \
    apt-get autoremove -y && rm -rf /var/lib/apt/lists/*

# 拷贝待用脚本并赋予权限
RUN cp /code/backend/wait-for-it.sh /usr/bin/wait-for-it.sh && \
    chmod +x /usr/bin/wait-for-it.sh

# 赋予 ARL 自带工具执行权限
RUN chmod +x /code/backend/app/tools/massdns || true && \
    chmod +x /code/backend/app/tools/wih/wih || true
